# HirePilot — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# ── Required ─────────────────────────────────────────────────────────────
# 32+ character random string used to encrypt API keys stored in the DB.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
HIREPILOT_SECRET_KEY=your-secret-key-here-at-least-32-chars

# ── Optional ─────────────────────────────────────────────────────────────
# Custom database path (default: ./hirepilot.db)
# HIREPILOT_DB_PATH=/data/hirepilot.db

# ── Logging ──────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
